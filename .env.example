# Azure Speech Service
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_region_here

# Azure OpenAI (if using Azure OpenAI)
USE_AZURE_OPENAI=True
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# OpenAI (if using OpenAI instead of Azure)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Alerting - Teams Webhook
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Alerting - Slack Webhook (alternative)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Meeting join URL
MEETING_JOIN_URL=https://teams.microsoft.com/l/meetup-join/...

# Detection Settings
TARGET_NAMES=Jack,Amichai
FUZZ_THRESHOLD=88
ROLLING_BUFFER_MINUTES=10
SUMMARY_WINDOW_MINUTES=5
TRIGGER_COOLDOWN_SECONDS=90
